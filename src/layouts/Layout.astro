---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Find the best AI tools for every task. Compare features, pricing, and user reviews." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | AI Tools Directory</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={Astro.url}>
  <link rel="stylesheet" href="/styles/global.css">
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
</head>
<body>
  <header>
    <nav>
      <a href="/">AI Tools Directory</a>
      <div class="nav-links">
        <a href="/categories">Categories</a>
        <a href="/about">About</a>
      </div>
    </nav>
  </header>
  
  <main>
    <slot />
  </main>

  <footer>
    <p>&copy; {new Date().getFullYear()} AI Tools Directory. All rights reserved.</p>
    <p>Affiliate Disclosure: We may earn commissions from qualifying purchases.</p>
  </footer>
</body>
</html>
